# Ghostty Configuration

# Appearance
theme = dark
font-family = "JetBrains Mono"
font-size = 14
cursor-style = block
cursor-blink = true

# Window
window-padding-x = 10
window-padding-y = 10
window-decoration = true
macos-titlebar-style = hidden

# Behavior
copy-on-select = true
confirm-close-surface = false
